table agregacoes_gold_ipynb
	lineageTag: 6e3c3aea-9afb-4c5e-a842-77a7a8c38d81

	measure 'Total Pontos' = SUM('agregacoes_gold_ipynb'[total_pontos])
		formatString: 0
		lineageTag: edf11c52-20fe-407b-a3a8-03c16584b559

	measure 'Total Vitorias' = SUM('agregacoes_gold_ipynb'[vitorias])
		formatString: 0
		lineageTag: 0934aec5-08c7-4c0c-a1d6-89f6d92206b3

	measure 'Total Corridas' =
			
			MAXX(
			    VALUES('agregacoes_gold_ipynb'[piloto]),
			    CALCULATE(MAX('agregacoes_gold_ipynb'[corridas_disputadas]))
			)
		formatString: 0
		lineageTag: faf73ee1-9631-45e5-8d1f-38c59af8781c

	measure 'Pct Conclusao Media' =
			
			AVERAGEX(
			    FILTER(
			        SUMMARIZE(
			            'agregacoes_gold_ipynb',
			            'agregacoes_gold_ipynb'[piloto],
			            'agregacoes_gold_ipynb'[ano],
			            "pct", MAXX(
			                FILTER(
			                    'agregacoes_gold_ipynb',
			                    'agregacoes_gold_ipynb'[piloto] = EARLIER('agregacoes_gold_ipynb'[piloto]) &&
			                    'agregacoes_gold_ipynb'[ano] = EARLIER('agregacoes_gold_ipynb'[ano])
			                ),
			                'agregacoes_gold_ipynb'[pct_conclusao]
			            )
			        ),
			        [pct] > 0
			    ),
			    [pct]
			)
		formatString: 0
		lineageTag: a14c4ad2-00ed-451e-b621-28a974ead935

	measure 'Pts por Corrida' = DIVIDE(SUM('agregacoes_gold_ipynb'[total_pontos]), MAX('agregacoes_gold_ipynb'[corridas_disputadas]))
		lineageTag: 09e8c08c-33b4-4b39-a260-0bf4ad650896

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure Lider = ```
			
			VAR TabelaFiltrada = 
			    ADDCOLUMNS(
			        VALUES('agregacoes_gold_ipynb'[piloto]),
			        "pts", CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos]))
			    )
			VAR MaxPts = MAXX(TabelaFiltrada, [pts])
			RETURN
			    MAXX(
			        FILTER(TabelaFiltrada, [pts] = MaxPts),
			        'agregacoes_gold_ipynb'[piloto]
			    )
			```
		lineageTag: ce67be41-a7c7-47ae-903d-91bc99c5c79d

	measure 'Pontos Lider' =
			
			MAXX(
			    VALUES('agregacoes_gold_ipynb'[piloto]),
			    CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos]))
			)
		formatString: 0
		lineageTag: cbf2b10c-4c98-415b-a9c5-0c8cd8a3cfe8

	measure 'Equipe Lider' = ```
			
			VAR MaxPontos = 
			    MAXX(
			        VALUES('agregacoes_gold_ipynb'[Equipe]),
			        CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos]))
			    )
			RETURN
			    MAXX(
			        FILTER(
			            VALUES('agregacoes_gold_ipynb'[Equipe]),
			            CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos])) = MaxPontos
			        ),
			        'agregacoes_gold_ipynb'[Equipe]
			    )
			```
		lineageTag: 3ec8b4fe-35db-472a-972e-f9a3c1f6d450

	measure 'Pontos Equipe' =
			
			MAXX(
			    VALUES('agregacoes_gold_ipynb'[Equipe]),
			    CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos]))
			)
		formatString: 0
		lineageTag: 7221b4c6-bdfc-468f-a291-152b7f620f18

	measure 'Total Vitorias Equipe' =
			
			SUMX(
			    SUMMARIZE(
			        'agregacoes_gold_ipynb',
			        'agregacoes_gold_ipynb'[Equipe],
			        'agregacoes_gold_ipynb'[ano],
			        "vit", MAX('agregacoes_gold_ipynb'[vitorias])
			    ),
			    [vit]
			)
		formatString: 0
		lineageTag: 8b41b4dd-ea6a-4009-a32f-dbb728743bb4

	measure 'Total Corridas Equipe' =
			
			MAXX(
			    FILTER(
			        'agregacoes_gold_ipynb',
			        'agregacoes_gold_ipynb'[posicao_campeonato] = 1
			    ),
			    'agregacoes_gold_ipynb'[corridas_disputadas]
			)
		formatString: 0
		lineageTag: f13d51bf-f29c-4c96-bbbf-164309560406

	measure 'Total Sprint Equipe' =
			
			SUMX(
			    SUMMARIZE(
			        'agregacoes_gold_ipynb',
			        'agregacoes_gold_ipynb'[Equipe],
			        'agregacoes_gold_ipynb'[ano],
			        "spr", MAX('agregacoes_gold_ipynb'[vitorias_sprint])
			    ),
			    [spr]
			)
		formatString: 0
		lineageTag: 0b6d1bd3-b192-4b77-8c9f-22877a99a983

	measure 'Corridas Disputadas Equipe' =
			
			MAXX(
			    SUMMARIZE(
			        'agregacoes_gold_ipynb',
			        'agregacoes_gold_ipynb'[Equipe],
			        'agregacoes_gold_ipynb'[ano],
			        "corr", MAX('agregacoes_gold_ipynb'[corridas_disputadas])
			    ),
			    [corr]
			)
		formatString: 0
		lineageTag: 8da390b9-4640-4c12-bec8-a40760911d21

	measure 'Lider 2025' =
			
			CALCULATE(
			    VAR MaxPts = MAXX(
			        VALUES('agregacoes_gold_ipynb'[piloto]),
			        CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos]))
			    )
			    RETURN
			    MAXX(
			        FILTER(
			            VALUES('agregacoes_gold_ipynb'[piloto]),
			            CALCULATE(SUM('agregacoes_gold_ipynb'[total_pontos])) = MaxPts
			        ),
			        'agregacoes_gold_ipynb'[piloto]
			    ),
			    'agregacoes_gold_ipynb'[ano] = 2025
			)
		lineageTag: 5f3b30da-2ab9-492c-95f7-0fdaa2fe3d2a


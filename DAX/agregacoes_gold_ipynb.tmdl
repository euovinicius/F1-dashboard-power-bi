	measure 'Mudanca Posicao' = ```
			
			VAR Pos2025 = 
			    CALCULATE(
			        MIN('agregacoes_gold_ipynb'[posicao_campeonato]),
			        'agregacoes_gold_ipynb'[ano] = 2025
			    )
			VAR Pos2026 = 
			    CALCULATE(
			        MIN('agregacoes_gold_ipynb'[posicao_campeonato]),
			        'agregacoes_gold_ipynb'[ano] = 2026
			    )
			RETURN
			    Pos2025 - Pos2026
			```
		formatString: 0
		lineageTag: cb0b7481-8e0d-4faa-9edc-a767b22436cc

	measure 'Posicao 2025' =
			
